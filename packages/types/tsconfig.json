{
	"extends": "@saedgewell/config/typescript/base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"noEmit": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"incremental": false
	},
	"include": ["src"],
	"exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
