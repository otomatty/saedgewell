{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "React",
	"extends": "./base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"lib": ["dom", "dom.iterable", "esnext"],
		"module": "esnext",
		"target": "es5",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
